rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자 컬렉션 - 누구나 읽기 가능 (로그인 검증용), 쓰기는 인증 후
    match /admins/{adminId} {
      allow read: if true;
      allow write: if true;
    }

    // 신청 컬렉션
    match /applications/{docId} {
      allow read, write: if true;
    }

    // 사용자 컬렉션
    match /users/{docId} {
      allow read, write: if true;
    }

    // 전문가(법무사) 컬렉션
    match /experts/{docId} {
      allow read, write: if true;
    }

    // 관리자 알림 컬렉션
    match /adminNotifications/{docId} {
      allow read, write: if true;
    }

    // 기타 모든 컬렉션
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
